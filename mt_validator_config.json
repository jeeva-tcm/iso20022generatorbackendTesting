{
    "constraints": {
        "date_format": {
            "pattern": "^\\d{6}$",
            "description": "YYMMDD format",
            "validation_rule": "Must be valid date in YYMMDD format"
        },
        "currency_code": {
            "pattern": "^[A-Z]{3}$",
            "description": "ISO 4217 3-letter currency code",
            "validation_rule": "Must be a valid ISO 4217 currency code"
        },
        "amount": {
            "pattern": "^\\d{1,12}(,\\d{0,5})?$",
            "description": "Up to 15 digits including decimal comma",
            "validation_rule": "Maximum 15 characters, comma as decimal separator"
        },
        "bic": {
            "pattern": "^[A-Z]{6}[A-Z0-9]{2}([A-Z0-9]{3})?$",
            "description": "8 or 11 character SWIFT BIC",
            "validation_rule": "Must be a valid BIC8 or BIC11"
        },
        "iban": {
            "pattern": "^[A-Z]{2}\\d{2}[A-Z0-9]{4,30}$",
            "description": "ISO 13616 International Bank Account Number",
            "validation_rule": "Must follow ISO 13616 structure for the specific country"
        }
    },
    "message_types": {
        "MT103": {
            "description": "Single Customer Credit Transfer",
            "mx_mapping": "pacs.008.001.08",
            "fields": [
                {
                    "tag": "20",
                    "name": "Sender's Reference",
                    "mandatory": true,
                    "format": "16x",
                    "description": "Unique reference for transaction",
                    "example": "REF123456789"
                },
                {
                    "tag": "23B",
                    "name": "Bank Operation Code",
                    "mandatory": true,
                    "format": "4!a",
                    "allowed_values": [
                        "CRED",
                        "SPAY",
                        "SISS",
                        "SPRI"
                    ],
                    "description": "Type of operation"
                },
                {
                    "tag": "32A",
                    "name": "Value Date/Currency/Amount",
                    "mandatory": true,
                    "format": "6!n3!a15d",
                    "description": "Payment date, currency, and amount",
                    "example": "250308USD10000,"
                },
                {
                    "tag": "50K",
                    "name": "Ordering Customer",
                    "mandatory": true,
                    "format": "4*35x",
                    "description": "Sender details (Account, Name, Address)"
                },
                {
                    "tag": "59",
                    "name": "Beneficiary Customer",
                    "mandatory": true,
                    "format": "[/34x]n4*35x",
                    "description": "Receiver details (Account, Name, Address)"
                },
                {
                    "tag": "71A",
                    "name": "Details of Charges",
                    "mandatory": true,
                    "format": "3!a",
                    "allowed_values": [
                        "OUR",
                        "SHA",
                        "BEN"
                    ],
                    "description": "Charge responsibility"
                }
            ]
        },
        "MT202": {
            "description": "General Financial Institution Transfer",
            "mx_mapping": "pacs.009.001.08",
            "fields": [
                {
                    "tag": "20",
                    "name": "Transaction Reference Number",
                    "mandatory": true,
                    "format": "16x",
                    "description": "Sender's unique reference"
                },
                {
                    "tag": "21",
                    "name": "Related Reference",
                    "mandatory": true,
                    "format": "16x",
                    "description": "Reference of the underlying transaction"
                },
                {
                    "tag": "32A",
                    "name": "Value Date/Currency/Amount",
                    "mandatory": true,
                    "format": "6!n3!a15d",
                    "description": "Settlement details"
                },
                {
                    "tag": "52A",
                    "name": "Ordering Institution",
                    "mandatory": false,
                    "format": "[/34x]n8!a2!a2!c[3!c]",
                    "description": "Institution initiating the transfer"
                },
                {
                    "tag": "58A",
                    "name": "Beneficiary Institution",
                    "mandatory": true,
                    "format": "[/34x]n8!a2!a2!c[3!c]",
                    "description": "Final receiving bank"
                }
            ]
        },
        "MT940": {
            "description": "Customer Statement Message",
            "mx_mapping": "camt.053.001.08",
            "fields": [
                {
                    "tag": "20",
                    "name": "Transaction Reference",
                    "mandatory": true,
                    "format": "16x",
                    "description": "Statement reference"
                },
                {
                    "tag": "25",
                    "name": "Account Identification",
                    "mandatory": true,
                    "format": "35x",
                    "description": "The account for which the statement is sent"
                },
                {
                    "tag": "28C",
                    "name": "Statement Number/Sequence Number",
                    "mandatory": true,
                    "format": "5!n[/5!n]",
                    "description": "Sequence of the statement"
                },
                {
                    "tag": "60F",
                    "name": "Opening Balance",
                    "mandatory": true,
                    "format": "1!a6!n3!a15d",
                    "description": "Balance at the start of the period"
                },
                {
                    "tag": "61",
                    "name": "Statement Line",
                    "mandatory": false,
                    "format": "6!n[4!n]2!a[1!a]15d1!a3!c16x[//16x][34x]",
                    "description": "Specific transaction details"
                },
                {
                    "tag": "62F",
                    "name": "Closing Balance",
                    "mandatory": true,
                    "format": "1!a6!n3!a15d",
                    "description": "Balance at the end of the period"
                }
            ]
        },
        "MT210": {
            "description": "Notice to Receive",
            "mx_mapping": "camt.057.001.06",
            "fields": [
                {
                    "tag": "20",
                    "name": "Transaction Reference",
                    "mandatory": true,
                    "format": "16x"
                },
                {
                    "tag": "25",
                    "name": "Account Identification",
                    "mandatory": true,
                    "format": "35x"
                },
                {
                    "tag": "30",
                    "name": "Expected Value Date",
                    "mandatory": true,
                    "format": "6!n",
                    "example": "250308"
                },
                {
                    "tag": "32B",
                    "name": "Currency/Amount",
                    "mandatory": true,
                    "format": "3!a15d"
                },
                {
                    "tag": "50",
                    "name": "Ordering Customer/Institution",
                    "mandatory": false,
                    "format": "4*35x"
                }
            ]
        },
        "MT196": {
            "description": "Answers (Investigation Respones)",
            "mx_mapping": "camt.029.001.09",
            "fields": [
                {
                    "tag": "20",
                    "name": "Transaction Reference",
                    "mandatory": true,
                    "format": "16x"
                },
                {
                    "tag": "21",
                    "name": "Related Reference",
                    "mandatory": true,
                    "format": "16x"
                },
                {
                    "tag": "79",
                    "name": "Narrative (Resolution)",
                    "mandatory": true,
                    "format": "35*50x"
                },
                {
                    "tag": "11S",
                    "name": "Original Message Header",
                    "mandatory": false,
                    "format": "3!n6!n[4!n]"
                }
            ]
        }
    }
}