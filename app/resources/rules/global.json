[
    {
        "rule_id": "L3_CURRENCY_001",
        "description": "Currency Decimal Precision Check",
        "type": "currency_amount",
        "selector": ".*Amt$",
        "severity": "ERROR",
        "layer": 3
    },
    {
        "rule_id": "L3_COUNTRY_001",
        "description": "Country Code Compliance (ISO 3166-1 Alpha-2)",
        "type": "codelist",
        "selector": ".*\\.Ctry$",
        "list_name": "country",
        "severity": "ERROR",
        "layer": 3
    },
    {
        "rule_id": "L3_CHRGBR_001",
        "description": "Charge Bearer Code Validation",
        "type": "codelist",
        "selector": ".*ChrgBr$",
        "list_name": "charge_bearer",
        "severity": "ERROR",
        "layer": 3
    },
    {
        "rule_id": "E001",
        "description": "Town name mandatory for post-Nov 2026 messages",
        "type": "expression",
        "expression": "check_address(KEY)",
        "selector": ".*PstlAdr$",
        "severity": "ERROR",
        "layer": 3
    },
    {
        "rule_id": "W005",
        "description": "Instruction ID is unusually long",
        "type": "expression",
        "expression": "len(str(VALUE)) <= 35",
        "selector": ".*InstrId$",
        "severity": "WARNING",
        "layer": 3
    },
    {
        "rule_id": "L3_BIC_DIRECTORY_001",
        "description": "BIC Existence in SWIFT Directory",
        "type": "bic",
        "selector": ".*BIC.*|.*AnyBIC.*",
        "severity": "WARNING",
        "layer": 3
    },
    {
        "rule_id": "L3_URGENT_DATE_001",
        "description": "Urgent payments should normally be settled on the current date.",
        "type": "expression",
        "expression": "not (exists('SvcLvl.Cd') and 'URGT' in str(DATA.get('SvcLvl.Cd'))) or DATA.get('IntrBkSttlmDt') == datetime.now().strftime('%Y-%m-%d')",
        "severity": "WARNING",
        "layer": 3
    },
    {
        "rule_id": "L3-PURPOSE-LIMIT",
        "description": "Conditional Amount Limit based on Purpose Code",
        "type": "expression",
        "selector": ".*Purp\\.Cd$",
        "expression": "check_purpose_limit(KEY, VALUE)",
        "severity": "ERROR",
        "layer": 3
    },
    {
        "rule_id": "L3_IBAN_CURR_001",
        "description": "IBAN Based Currency Validation",
        "type": "expression",
        "selector": ".*DbtrAcct\\.Id\\.IBAN$",
        "expression": "check_iban_currency(KEY, VALUE)",
        "severity": "ERROR",
        "layer": 3
    },
    {
        "rule_id": "L3_LEI_NOT_BIC",
        "description": "LEI cannot replace BIC for financial institution agents. CBPR+ requires BICFI.",
        "layer": 3,
        "severity": "ERROR",
        "type": "expression",
        "selector": ".*FinInstnId\\.LEI$",
        "expression": "exists(KEY.rsplit('.LEI', 1)[0] + '.BICFI') if '.' in KEY else True"
    },
    {
        "rule_id": "L3_INTRMY_ORDER_1",
        "description": "IntrmyAgt2 cannot exist without IntrmyAgt1.",
        "layer": 3,
        "severity": "ERROR",
        "condition": "exists('Document') or exists('BusMsg')",
        "expression": "not any(k.endswith('IntrmyAgt2.FinInstnId.BICFI') for k in DATA.keys()) or any(k.endswith('IntrmyAgt1.FinInstnId.BICFI') for k in DATA.keys())"
    },
    {
        "rule_id": "L3_INTRMY_ORDER_2",
        "description": "IntrmyAgt3 cannot exist without IntrmyAgt2.",
        "layer": 3,
        "severity": "ERROR",
        "condition": "exists('Document') or exists('BusMsg')",
        "expression": "not any(k.endswith('IntrmyAgt3.FinInstnId.BICFI') for k in DATA.keys()) or any(k.endswith('IntrmyAgt2.FinInstnId.BICFI') for k in DATA.keys())"
    },
    {
        "rule_id": "L3_PURPOSE_001",
        "description": "ISO Purpose Code Validation (SR2025)",
        "type": "codelist",
        "selector": ".*Purp\\.Cd$",
        "list_name": "purp",
        "severity": "ERROR",
        "layer": 3
    },
    {
        "rule_id": "L3_CTGYPURP_001",
        "description": "ISO Category Purpose Code Validation (SR2025)",
        "type": "codelist",
        "selector": ".*CtgyPurp\\.Cd$",
        "list_name": "ctgypurp",
        "severity": "ERROR",
        "layer": 3
    },
    {
        "rule_id": "L3_STTLM_CLRG_001",
        "description": "If Settlement Method is CLRG (Clearing System), Clearing System (ClrSys) identity must be present.",
        "condition": "Document..GrpHdr.SttlmInf.SttlmMtd == 'CLRG'",
        "expression": "exists(Document..GrpHdr.SttlmInf.ClrSys) or exists(Document..CdtTrfTxInf.SttlmInf.ClrSys)",
        "severity": "ERROR",
        "layer": 3
    }
]