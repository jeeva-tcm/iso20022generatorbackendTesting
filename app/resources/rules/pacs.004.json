[
    {
        "rule_id": "PACS004_001",
        "description": "Payment Return: Debtor identification should follow standard Party rules (Name, Address, or ID).",
        "condition": "exists(Document.PmtRtr.TxInf.OrgnlTxRef.Dbtr)",
        "expression": "exists(Document.PmtRtr.TxInf.OrgnlTxRef.Dbtr.Nm) or exists(Document.PmtRtr.TxInf.OrgnlTxRef.Dbtr.PstlAdr) or exists(Document.PmtRtr.TxInf.OrgnlTxRef.Dbtr.Id)",
        "severity": "WARNING",
        "layer": 3
    },
    {
        "rule_id": "PACS004_RSN_CODE_VALID",
        "description": "Payment Return reason code (RtrRsnInf.Rsn.Cd) must be a valid ExternalReturnReason1Code.",
        "selector": "^Document\\.PmtRtr\\.TxInf(\\[\\d+\\])?\\.RtrRsnInf(\\[\\d+\\])?\\.Rsn\\.Cd$",
        "type": "codelist",
        "list_name": "return_reason",
        "severity": "ERROR",
        "layer": 3
    },
    {
        "rule_id": "PACS004_RTRDAMT_LE_ORGNLAMT",
        "description": "Returned interbank settlement amount must not exceed the original interbank settlement amount.",
        "condition": "exists(Document.PmtRtr.TxInf.RtrdIntrBkSttlmAmt) and exists(Document.PmtRtr.TxInf.OrgnlIntrBkSttlmAmt)",
        "expression": "float(Document.PmtRtr.TxInf.RtrdIntrBkSttlmAmt) <= float(Document.PmtRtr.TxInf.OrgnlIntrBkSttlmAmt)",
        "severity": "ERROR",
        "layer": 3,
        "errorMessage": "RtrdIntrBkSttlmAmt exceeds the original IntrBkSttlmAmt — a return cannot exceed the original payment.",
        "fix": "Set <RtrdIntrBkSttlmAmt> ≤ <OrgnlIntrBkSttlmAmt>, deducting any return charges if applicable."
    },
    {
        "rule_id": "PACS004_RTRDAMT_POSITIVE",
        "description": "Returned amount must be greater than zero.",
        "condition": "exists(Document.PmtRtr.TxInf.RtrdIntrBkSttlmAmt)",
        "expression": "float(Document.PmtRtr.TxInf.RtrdIntrBkSttlmAmt) > 0",
        "severity": "ERROR",
        "layer": 3
    },
    {
        "rule_id": "PACS004_NO_PRTRY_RSN",
        "description": "CBPR+: Return reason must use <Cd> not <Prtry>.",
        "selector": "^Document\\.PmtRtr\\.TxInf(\\[\\d+\\])?\\.RtrRsnInf(\\[\\d+\\])?\\.Rsn\\.Prtry$",
        "type": "expression",
        "expression": "False",
        "severity": "ERROR",
        "layer": 3,
        "errorMessage": "Return reason must use the standard <Cd> code, not <Prtry>, per CBPR+.",
        "fix": "Replace <Prtry>...</Prtry> with <Cd>...</Cd> using an ExternalReturnReason1Code."
    },
    {
        "rule_id": "PACS004_ORGNLUETR_REQUIRED",
        "description": "OrgnlUETR is mandatory in pacs.004 TxInf to identify which payment is being returned.",
        "condition": "exists(Document.PmtRtr.TxInf)",
        "mandatory_fields": [
            "Document.PmtRtr.TxInf.OrgnlUETR"
        ],
        "severity": "ERROR",
        "layer": 3
    }
]
