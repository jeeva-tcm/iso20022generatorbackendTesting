    "validation_rules": {
        "description": "Rules to apply during ISO 20022 message validation",
        "rules": [
            {
                "ruleId": "CUT001",
                "field": "CreDtTm",
                "description": "Creation date-time must be before cut-off for the target country and payment system"
            },
            {
                "ruleId": "CUT002",
                "field": "ReqdExctnDt",
                "description": "Requested execution date must be a valid business day (not weekend or holiday)"
            },
            {
                "ruleId": "CUT003",
                "field": "IntrBkSttlmDt",
                "description": "Interbank settlement date must align with cut-off timing of the settlement system"
            },
            {
                "ruleId": "CUT004",
                "description": "If submission time is after cut-off, value date must be next business day"
            }
        ]
    }
