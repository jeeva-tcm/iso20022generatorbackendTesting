      "checksum": {
        "algorithm": "ISO 7064 MOD 97-10",
        "mod_97_result": 1,
        "valid": true
      },
      "status": "ACTIVE",
      "note": "Standard valid LEI with alphanumeric LOU prefix"
    }
  ],
  "lei_checksum_validation": {
