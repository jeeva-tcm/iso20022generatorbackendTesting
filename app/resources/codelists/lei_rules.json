{
  "lei_structure": {
    "total_length": 20,
    "format": "[LOU_PREFIX(4)][RESERVED(2)][ENTITY_ID(12)][CHECK_DIGITS(2)]",
    "parts": [
      {
        "name": "LOU Prefix",
        "position": "1-4",
        "length": 4,
        "description": "Local Operating Unit identifier assigned by GLEIF",
        "example": "5493"
      },
      {
        "name": "Reserved",
        "position": "5-6",
        "length": 2,
        "description": "Always '00' — reserved for future use",
        "example": "00"
      },
      {
        "name": "Entity ID",
        "position": "7-18",
        "length": 12,
        "description": "Unique alphanumeric entity identifier",
        "example": "TRUWO2CD2G56"
      },
      {
        "name": "Check Digits",
        "position": "19-20",
        "length": 2,
        "description": "ISO 7064 MOD 97-10 checksum digits",
        "valid_range": "02 to 97",
        "reserved_values": ["00", "01"],
        "example": "92"
      }
    ]
  },
  "lei_valid_examples": [
    {
      "id": "V001",
      "lei": "549300TRUWO2CD2G5692",
